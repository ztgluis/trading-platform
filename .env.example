# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# CCXT (crypto exchange) — required for crypto data
CCXT_API_KEY=your_ccxt_api_key_here
CCXT_API_SECRET=your_ccxt_api_secret_here

# Schwab Trader API — required for live execution (M8/M9)
SCHWAB_API_KEY=your_schwab_api_key_here
SCHWAB_API_SECRET=your_schwab_api_secret_here
SCHWAB_REDIRECT_URI=https://localhost:8080/callback

# Supabase — required for database persistence (M6+)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
